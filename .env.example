# Environment Variables for Nexus HR Buddy

## Required for Local Development and Deployment

# Port Configuration
PORT=3000

# Frontend Base Path (use / for root deployment)
BASE_PATH=/

# Node Environment
NODE_ENV=production

## Cloudflare Deployment Secrets
# These should be set as secrets in Cloudflare Pages Dashboard
# or in GitHub Secrets for CI/CD deployment

# CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
# CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

## Application Environment Variables
# Add any application-specific environment variables below
# These should be configured in Cloudflare Pages Environment Variables section

# Database Configuration (if using external database)
# DATABASE_URL=postgresql://user:password@host:port/database

# API Base URL (point to your deployed API server)
# API_BASE_URL=https://your-api-server.com

# Authentication & Services
# Configure these in Cloudflare Pages dashboard for production
# Frontend (Vite requires VITE_ prefix for client-side env vars)
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# VITE_CLERK_PROXY_URL=
# Backend
# CLERK_SECRET_KEY=

# Payment Integration
# STRIPE_PUBLIC_KEY=
# STRIPE_SECRET_KEY=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# Email Service
# EMAIL_SERVICE_API_KEY=

# Google Cloud Storage (if used)
# GOOGLE_CLOUD_PROJECT_ID=
# GOOGLE_CLOUD_STORAGE_BUCKET=

# Owner Emails
OWNER_EMAILS=your-email@example.com

## Notes:
# 1. Never commit actual secrets to version control
# 2. Copy this file to .env for local development
# 3. Set production values in Cloudflare Pages Dashboard > Settings > Environment Variables
# 4. For GitHub Actions deployment, set secrets in GitHub Repository Settings
